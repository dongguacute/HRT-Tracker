{
  "name": "hrt-tracker-backend",
  "main": "packages/workers/backend/src/index.tsx",
  "compatibility_date": "2025-08-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "build/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "USER_STORAGE",
        "class_name": "UserStorage"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["UserStorage"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
